{
  "manifest_version": 3,
  "name": "OTMBangla AI Companion",
  "version": "1.0.0",
  "description": "Interactive AI companion side panel that answers questions based on your current webpage content.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.eprocure.gov.bd/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
